# Shopline API Configuration
SHOPLINE_HANDLE=your-store-handle
SHOPLINE_ACCESS_TOKEN=your-access-token
SHOPLINE_APP_KEY=your-app-key
SHOPLINE_APP_SECRET=your-app-secret
SHOPLINE_REDIRECT_URI=https://your-app.com/auth/callback
SHOPLINE_BASE_URL=https://{handle}.myshopline.com/admin/openapi

# Optional: Blog collection configuration
DEFAULT_BLOG_COLLECTION_HANDLE=blog
DEFAULT_BLOG_COLLECTION_TITLE=Blog

# Example for testing
# SHOPLINE_HANDLE=teststore
# SHOPLINE_ACCESS_TOKEN=eyJhbGciOiJIUzUxMiJ9...
# SHOPLINE_APP_KEY=abc123
# SHOPLINE_APP_SECRET=def456
# SHOPLINE_REDIRECT_URI=http://localhost:3000/auth/callback