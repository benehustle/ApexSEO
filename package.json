    "date-fns": "^2.30.0",
    "dompurify": "^3.3.1",
    "driver.js": "^1.4.0",
    "express": "^5.2.1",
    "firebase": "^10.14.1",
    "lucide-react": "^0.294.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.2",
    "react-joyride": "^2.9.3",
    "react-router-dom": "^6.20.1",
    "react-window": "^2.2.4",
    "recharts": "^3.6.0",
    "stripe": "^20.2.0",
    "xml2js": "^0.6.2",
    "zod": "^3.25.76"
